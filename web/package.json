{
  "name": "tdf-web",
  "version": "0.1.0",
  "private": true,
  "description": "TdF live dashboard for Contentstack Launch (Next.js + Edge Functions)",
  "type": "module",
  "scripts": {
    "build:edge": "node scripts/bundle-edge.mjs",
    "dev": "npm run build:edge && concurrently -k \"node scripts/dev-api.mjs\" \"next dev --port 3000\"",
    "dev:next": "next dev --port 3000",
    "build": "npm run build:edge && next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "validate:local": "npm run build:edge && node scripts/validate-local.mjs",
    "validate:launch": "node scripts/validate-launch.mjs"
  },
  "dependencies": {
    "next": "^15.5.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.1",
    "@types/node": "^24.0.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "concurrently": "^9.2.1",
    "esbuild": "^0.25.0",
    "tailwindcss": "^4.3.1",
    "typescript": "^5.9.3"
  }
}
